# ============================================================
# DAINEKU — Required Environment Variables
# Set ALL of these in Vercel: Settings → Environment Variables
# ============================================================

# Supabase — get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare R2 — get from: dash.cloudflare.com → R2 → your bucket → Manage R2 API tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=jdm-photos
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# Admin — set to a long random string, this is your admin panel URL path
# Access admin at: yourdomain.com/[ADMIN_SECRET_PATH]
ADMIN_SECRET_PATH=change-this-to-a-long-random-string

# Optional: turn off turbopack if you see build issues
# NEXT_TURBOPACK=0
